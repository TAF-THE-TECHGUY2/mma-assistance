APP_NAME="Meridian Medical Assistance"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Johannesburg
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mma
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Notification emails are queued (non-blocking + auto-retry on provider rate
# limits). This REQUIRES a running worker:  php artisan queue:work
# In production keep it alive with Supervisor/systemd. (Set to "sync" to send
# inline without a worker — fine on plans without strict per-second limits.)
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail ---------------------------------------------------------------
# Mailtrap (Email Sending) via SMTP. Username is the literal "api"; the
# password is your Mailtrap API token. Use MAIL_MAILER=log to capture emails
# in storage/logs/laravel.log instead of sending.
# NOTE: On a new Mailtrap account the demo domain (hello@demomailtrap.co) can
# only send to your own account email until you verify a sending domain.
MAIL_MAILER=smtp
MAIL_HOST=live.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=api
MAIL_PASSWORD=your-mailtrap-api-token
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@demomailtrap.co"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum / SPA
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,127.0.0.1,127.0.0.1:5173,::1
SESSION_DOMAIN=localhost

# Frontend origin allowed for CORS
FRONTEND_URL=http://localhost:5173

VITE_APP_NAME="${APP_NAME}"
